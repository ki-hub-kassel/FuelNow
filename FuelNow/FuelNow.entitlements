<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		Temporärer CarPlay-Testpfad über EV-Charging-Capability:
		`com.apple.developer.carplay-charging` ist aktiv, bis Fueling
		offiziell freigeschaltet ist.

		Nach Fueling-Freigabe: Key auf `com.apple.developer.carplay-fueling`
		umstellen und `FuelNowFeatureFlags.carPlayCapabilityMode = .fueling` setzen,
		CarPlay-Scene bleibt aktiv — siehe
		`docs/CARPLAY.md`.
	-->
	<key>com.apple.developer.carplay-charging</key>
	<true/>
</dict>
</plist>
