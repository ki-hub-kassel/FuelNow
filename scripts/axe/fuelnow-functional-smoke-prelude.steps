# FuelNow — AXe-Prelude (Simulator, DE-Labels): Launch → Karte → Einstellungen → Standort zentrieren.
# Vollständiger Pin-Test: ./scripts/run-fuelnow-functional-smoke.sh (liest AXLabel dynamisch).

sleep 6

tap --label "Einstellungen" --wait-timeout 30
sleep 2
tap --label "Fertig" --wait-timeout 20
sleep 1.5

tap --label "Karte auf Standort zentrieren" --wait-timeout 25
sleep 5
