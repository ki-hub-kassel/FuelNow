#!/usr/bin/env bash
# scripts/git-hooks/post-push
# Trigger: nach Push auf refs/heads/main
set -euo pipefail

if [[ "${FUELNOW_SKIP_POST_PUSH_RELEASE:-0}" == "1" ]]; then
  exit 0
fi

pushed_main=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_ref" == "refs/heads/main" && "$remote_ref" == "refs/heads/main" ]]; then
    if [[ "$local_sha" != "0000000000000000000000000000000000000000" ]]; then
      pushed_main=1
    fi
  fi
done

if [[ "$pushed_main" -ne 1 ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
"$repo_root/scripts/release-after-main-push.sh"

